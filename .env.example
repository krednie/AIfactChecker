# ── API Keys ──────────────────────────────────────
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXX
SARVAM_API_KEY=sk-XXXXXXXXXXXXXXXXXXXX

# ── Bing Search (live web evidence fallback) ───────
# Free tier: 1,000 calls/month
# Get key: https://portal.azure.com → Create → Bing Search v7
BING_SEARCH_API_KEY=
# BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search
# BING_SEARCH_RESULTS=8

# ── Model Settings ────────────────────────────────
GROQ_MODEL=llama3-70b-8192
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── RAG / FAISS ───────────────────────────────────
CHUNK_SIZE=384
CHUNK_OVERLAP=64
TOP_K=8
FAISS_INDEX_PATH=data/faiss.index
CHUNK_META_PATH=data/chunk_meta.pkl

# ── Scraper ───────────────────────────────────────
SCRAPER_RATE_LIMIT_SECONDS=1.5
CORPUS_JSONL_PATH=data/scraped_corpus.jsonl

# ── Backend ───────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
